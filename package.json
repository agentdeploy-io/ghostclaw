{
  "name": "ghostclaw-template",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade Ironclaw + Camoufox orchestration template with one-click deploy",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "bullmq": "^5.12.0",
    "camoufox-js": "^0.9.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.2",
    "pino": "^9.4.0",
    "playwright": "^1.49.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

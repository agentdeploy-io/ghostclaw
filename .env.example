# ===========================================
# GHOSTCLAW CONFIGURATION
# ===========================================

# Core runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=8787
LOG_LEVEL=info

# Security for internal API routes (/api/v1/*)
INTERNAL_API_TOKEN=

# Redis / queue
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=2

# Artifact storage
ARTIFACT_DIR=./data/artifacts

# ===========================================
# LLM CONFIGURATION (Required)
# ===========================================

# Main LLM for primary agent
MAIN_LLM_BASE_URL=https://llm.chutes.ai/v1
MAIN_LLM_API_KEY=
MAIN_LLM_MODEL=Qwen/Qwen3.5-397B-A17B-TEE

# Sub-agent LLM for secondary tasks
SUB_LLM_BASE_URL=https://llm.chutes.ai/v1
SUB_LLM_API_KEY=
SUB_LLM_MODEL=MiniMaxAI/MiniMax-M2.5-TEE

LLM_REQUEST_TIMEOUT_MS=120000

# ===========================================
# TELEGRAM INTEGRATION (Optional)
# ===========================================

ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_WEBHOOK_PATH=/webhook/telegram
TUNNEL_URL=

# ===========================================
# BROWSER AUTOMATION (Optional)
# ===========================================

BROWSER_PROVIDER=camoufox
BROWSER_HEADLESS=true
BROWSER_DEFAULT_TIMEOUT_MS=25000
BROWSER_CHALLENGE_KEYWORDS=captcha,verify you are human,security check,mfa,one-time code,unusual traffic,access denied
BROWSER_EXECUTABLE_PATH=

# Camoufox-specific
CAMOUFOX_WS_ENDPOINT=
CAMOUFOX_CONNECT_TIMEOUT_MS=30000

# ===========================================
# DEPLOYMENT CONFIGURATION
# ===========================================

# Ironclaw source (can be any fork)
IRONCLAW_GIT_URL=https://github.com/nearai/ironclaw
IRONCLAW_GIT_REF=v0.12.0
LIPPYCLAW_GIT_URL=https://github.com/lippycoin/lippyclaw
LIPPYCLAW_GIT_REF=main
WASM_CHANNELS_DIR=/home/ironclaw/.ironclaw/channels-v2
WASM_CHANNEL_FORCE_SYNC=telegram

# PostgreSQL (for Ironclaw runtime)
POSTGRES_DB=ironclaw
POSTGRES_USER=ironclaw
POSTGRES_PASSWORD=

# Domain and TLS
DOMAIN=localhost
ACME_EMAIL=

# Secrets
DATABASE_URL=
SECRETS_MASTER_KEY=
GATEWAY_AUTH_TOKEN=

# ===========================================
# VPS DEPLOYMENT (Optional)
# ===========================================

VPS_HOST=
VPS_USER=root
VPS_SSH_KEY=
VPS_REMOTE_DIR=/opt/ghostclaw

# Local ports
LOCAL_HTTP_PORT=8080
LOCAL_HTTPS_PORT=8443
IRONCLAW_HOST_PORT=8082

# Tunnel mode for local development
TUNNEL_MODE=cloudflared

# ===========================================
# MCP SERVERS (Optional)
# ===========================================

MCP_CAMOUFOX_DEFAULT_ENABLED=true
MCP_MENTOR_DEFAULT_ENABLED=true
MCP_VOICE_DEFAULT_ENABLED=true
MCP_CONTEXT7_DEFAULT_ENABLED=true

# Mentor-specific (if enabled)
MENTOR_NAME=Lippyclaw Mentor
MENTOR_PERSONA_FILE=./mentor/persona.md
MENTOR_MEMORY_FILE=./data/mentor/memory.json
ENABLE_MENTOR_VOICE=false
MENTOR_VOICE_PROVIDER=auto
MENTOR_VOICE_API_KEY=
MENTOR_FISH_API_BASE_URL=https://api.fish.audio
MENTOR_FISH_API_KEY=
MENTOR_FISH_TTS_ENDPOINT=https://api.fish.audio/v1/tts
MENTOR_FISH_ASR_ENDPOINT=https://api.fish.audio/v1/asr
MENTOR_FISH_MODEL=s1
MENTOR_FISH_REFERENCE_ID=
MENTOR_FISH_FORMAT=mp3
MENTOR_FISH_LATENCY=normal
MENTOR_FISH_NORMALIZE=true
MENTOR_FISH_IGNORE_TIMESTAMPS=true
MENTOR_FISH_TEMPERATURE=0.7
MENTOR_FISH_TOP_P=0.7
MENTOR_FISH_REPETITION_PENALTY=1.2
MENTOR_FISH_MAX_NEW_TOKENS=1024
MENTOR_FISH_CHUNK_LENGTH=240
MENTOR_VOICE_SAMPLE_PATH=./agents/mentor/master-voice.wav

# Voice-specific (if enabled)
ENABLE_VOICE=false
VOICE_MODE=run_api
VOICE_API_BASE_URL=https://llm.chutes.ai/v1
VOICE_API_KEY=
VOICE_RUN_ENDPOINT=https://llm.chutes.ai/v1/run
VOICE_WHISPER_MODEL=openai/whisper-large-v3-turbo
VOICE_CLONE_MODEL=sesame/csm-1b
VOICE_KOKORO_MODEL=hexgrad/Kokoro-82M
VOICE_ENABLE_KOKORO_FALLBACK=true
VOICE_SAMPLE_PATH=./data/voice/master-voice.wav
VOICE_CONTEXT_PATH=./data/voice/voice_context.txt

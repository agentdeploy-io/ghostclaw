# Core runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=8787
LOG_LEVEL=info

# Security for internal API routes (/api/v1/*)
INTERNAL_API_TOKEN=test_z125b9fdea484a5ab7f629769efc1959b8cbdua190f3e58f

# Redis / queue
REDIS_URL=redis://redis:6379
WORKER_CONCURRENCY=2

# Artifact storage
ARTIFACT_DIR=/data/artifacts

# Browser automation runtime
BROWSER_HEADLESS=true
BROWSER_DEFAULT_TIMEOUT_MS=25000
BROWSER_CHALLENGE_KEYWORDS=captcha,verify you are human,security check,mfa,one-time code,unusual traffic,access denied

# OpenAI-compatible main model (ChutesAI)
MAIN_LLM_BASE_URL=https://llm.chutes.ai/v1
MAIN_LLM_API_KEY=
MAIN_LLM_MODEL=Qwen/Qwen3.5-397B-A17B-TEE

# OpenAI-compatible sub-agent model
SUB_LLM_BASE_URL=https://llm.chutes.ai/v1
SUB_LLM_API_KEY=
SUB_LLM_MODEL=MiniMaxAI/MiniMax-M2.5-TEE
LLM_REQUEST_TIMEOUT_MS=120000

# Telegram integration
ENABLE_TELEGRAM=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated chat IDs allowed to issue commands (empty = allow all)
TELEGRAM_ALLOWED_CHAT_IDS=

# Deployment options
DOMAIN=localhost
ACME_EMAIL=
BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
BROWSER_PROVIDER=camoufox
CAMOUFOX_CONNECT_TIMEOUT_MS=30000

CAMOUFOX_WS_ENDPOINT=
IRONCLAW_GIT_URL=https://github.com/nearai/ironclaw
IRONCLAW_GIT_REF=v0.12.0
POSTGRES_DB=ironclaw
POSTGRES_USER=ironclaw
POSTGRES_PASSWORD=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
CAMOUFOX_HEADLESS=true
CAMOUFOX_DEFAULT_TIMEOUT_MS=25000
TUNNEL_MODE=cloudflared
VPS_HOST=replace_with_vps_host
VPS_USER=root
VPS_SSH_KEY=
VPS_REMOTE_DIR=/opt/ghostclaw
LOCAL_HTTP_PORT=8081
LOCAL_HTTPS_PORT=8444
IRONCLAW_HOST_PORT=8082
DATABASE_URL=
SECRETS_MASTER_KEY=
GATEWAY_AUTH_TOKEN=

FROM rust:1.92-bookworm AS builder

ARG IRONCLAW_GIT_URL
ARG IRONCLAW_GIT_REF

RUN test -n "$IRONCLAW_GIT_URL" || (echo "IRONCLAW_GIT_URL build arg is required" >&2; exit 1)
RUN test -n "$IRONCLAW_GIT_REF" || (echo "IRONCLAW_GIT_REF build arg is required" >&2; exit 1)

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    pkg-config \
    libssl-dev \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /src
RUN git clone "$IRONCLAW_GIT_URL" repo
WORKDIR /src/repo
RUN git checkout "$IRONCLAW_GIT_REF"

# Ensure libSQL cloud sync works (Turso/hrana over TLS).
RUN perl -0777 -i -pe 's#libsql\s*=\s*\{\s*version\s*=\s*"0\.6"\s*,\s*optional\s*=\s*true\s*,\s*default-features\s*=\s*false\s*,\s*features\s*=\s*\[[^\]]*\]\s*\}#libsql = { version = "0.6", optional = true, default-features = false, features = ["core", "replication", "remote", "tls"] }#smg' Cargo.toml \
  && grep -n 'libsql' Cargo.toml

# Allow internal Docker MCP endpoint for camoufox bridge.
RUN perl -0777 -i -pe 's#url_lower\.contains\("localhost"\)\s*\|\|\s*url_lower\.contains\("127\.0\.0\.1"\)#url_lower.contains("localhost") || url_lower.contains("127.0.0.1") || url_lower.contains("camoufox-mcp")#g' src/tools/mcp/config.rs \
  && perl -0777 -i -pe 's#d\.eq_ignore_ascii_case\("localhost"\)#d.eq_ignore_ascii_case("localhost") || d.eq_ignore_ascii_case("camoufox-mcp")#g' src/tools/mcp/config.rs \
  && grep -n 'camoufox-mcp' src/tools/mcp/config.rs

ENV CARGO_NET_RETRY=20 \
    CARGO_HTTP_TIMEOUT=600 \
    CARGO_HTTP_MULTIPLEXING=false \
    CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse

RUN cargo build --release --bin ironclaw || \
  (echo "Cargo build failed. Verify IRONCLAW_GIT_REF and Rust toolchain compatibility for edition 2024." >&2; exit 1)

FROM ubuntu:24.04

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    gosu \
  && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --shell /bin/bash ironclaw
WORKDIR /home/ironclaw

COPY --from=builder /src/repo/target/release/ironclaw /usr/local/bin/ironclaw
COPY docker/ironclaw-entrypoint.sh /usr/local/bin/ironclaw-entrypoint.sh

ENV HOME=/home/ironclaw

EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/ironclaw-entrypoint.sh"]
CMD ["ironclaw", "run"]
